<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>potter-poc — B₂ in the browser</title>
<style>
  :root { --fg:#1a1a2e; --mut:#666; --accent:#2a6df4; --exact:#e0533d; --line:#ddd; }
  * { box-sizing: border-box; }
  body { font: 15px/1.5 -apple-system, system-ui, sans-serif; color: var(--fg);
         max-width: 880px; margin: 24px auto; padding: 0 16px; }
  h1 { font-size: 20px; margin: 0 0 2px; }
  .sub { color: var(--mut); margin: 0 0 18px; font-size: 13px; }
  fieldset { border: 1px solid var(--line); border-radius: 8px; padding: 12px 14px; margin: 0 0 14px; }
  legend { font-weight: 600; font-size: 13px; padding: 0 6px; }
  label { display: inline-block; margin-right: 14px; font-size: 13px; }
  input, select, textarea { font: inherit; padding: 4px 6px; border: 1px solid #bbb; border-radius: 5px; }
  input[type=number] { width: 72px; }
  textarea { width: 100%; font-family: ui-monospace, Menlo, monospace; font-size: 13px; margin-top: 6px; }
  button { font: inherit; font-weight: 600; padding: 7px 18px; border: 0; border-radius: 6px;
           background: var(--accent); color: #fff; cursor: pointer; }
  button:disabled { background: #aaa; cursor: default; }
  .row { margin: 8px 0; }
  .note { font-size: 12px; color: var(--mut); }
  #status { font-size: 13px; margin: 10px 0; }
  .err { color: var(--exact); }
  table { border-collapse: collapse; width: 100%; margin-top: 10px; font-variant-numeric: tabular-nums; }
  th, td { text-align: right; padding: 3px 10px; border-bottom: 1px solid #eee; font-size: 13px; }
  th { color: var(--mut); font-weight: 600; }
  td:first-child, th:first-child { text-align: left; }
  canvas { border: 1px solid var(--line); border-radius: 8px; margin-top: 12px; max-width: 100%; }
  code { background: #f3f3f7; padding: 1px 5px; border-radius: 4px; font-size: 12.5px; }
  .layout { display: flex; gap: 18px; flex-wrap: wrap; align-items: flex-start; }
  .layout > div { flex: 1 1 360px; }
  #plots { width: 100%; min-height: 200px; }
  details.defs { margin: 0 0 14px; }
  details.defs summary { cursor: pointer; font-size: 13px; color: var(--mut); font-weight: 600; }
  table.defs { width: auto; margin-top: 8px; }
  table.defs th, table.defs td { text-align: left; padding: 3px 18px 3px 0; border: 0; font-size: 12.5px; }
  table.defs th { color: var(--mut); }
</style>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
</head>
<body>
  <h1>Second virial coefficient B₂(T) — in the browser</h1>
  <p class="sub">Type a pair potential V(r). It is compiled to a WebAssembly module
     <em>in your browser</em> (AOT) and run natively to integrate
     B₂ = −2π ∫₀<sup>∞</sup> (e<sup>−V/T</sup>−1) r² dr. Because V(r) is
     T-independent, the same pass also returns the first two T-derivatives
     (analytically) and the effective repulsive exponent
     n_eff = −3(B₂+T·B₂′)/(2T·B₂′+T²·B₂″).</p>
  <p class="sub">Everything is in <b>reduced (dimensionless) units</b> — the model
     potentials reduce with their own energy scale ε and length scale σ. The axes are
     the dimensionless groups <b>B₂/σ³</b> vs <b>k<sub>B</sub>T/ε</b>; n_eff is
     dimensionless. See the definitions below for how each starred quantity maps to a
     real fluid (ε in J, σ in m, μ in C·m).</p>

  <fieldset>
    <legend>potential</legend>
    <div class="row">
      <label>preset
        <select id="preset">
          <option value="lj">Lennard-Jones (12-6)</option>
          <option value="mie">Mie  (n–m)</option>
          <option value="stockmayer">Stockmayer (12-6-3)</option>
          <option value="exp">EXP  φ₀ e^(−r/r₀)</option>
          <option value="sw">Square-well (λ)</option>
          <option value="inv">Inverse power  ε(σ/r)ⁿ</option>
          <option value="custom">Custom…</option>
        </select>
      </label>
      <label id="nwrap" hidden>n <input id="nexp" type="number" value="12" min="4" step="1" /></label>
      <label id="mwrap" hidden>m <input id="mexp" type="number" value="6" min="4" step="1" /></label>
      <label id="mu2wrap" hidden>(μ*)² <input id="mu2" type="number" value="2" min="0" step="0.5" /></label>
      <label id="lamwrap" hidden>λ <input id="lam" type="number" value="1.5" min="1.01" step="0.1" /></label>
    </div>
    <div class="row">
      <textarea id="dsl" rows="2" spellcheck="false">4*eps*((sig/r)**12 - (sig/r)**6)</textarea>
      <div class="note">Python-like: <code>+ - * /</code>, <code>**</code> power,
        <code>exp ln log sqrt sin cos abs pow</code>, variables <code>r</code>, <code>eps</code>, <code>sig</code>
        (reduced: <code>eps = sig = 1</code>).</div>
    </div>
  </fieldset>

  <fieldset>
    <legend>temperature range</legend>
    <label>T*min <input id="tmin" type="number" value="1.3" step="0.1" /></label>
    <label>T*max <input id="tmax" type="number" value="8" step="0.5" /></label>
    <label>points <input id="npts" type="number" value="24" min="2" step="1" /></label>
    <label>spacing
      <select id="tspace">
        <option value="lin">linear</option>
        <option value="log">log</option>
      </select>
    </label>
    <button id="go" disabled>Compute B₂(T)</button>
  </fieldset>

  <details class="defs">
    <summary>reduced-unit definitions</summary>
    <table class="defs">
      <tr><th>quantity</th><th>definition</th><th>maps to a real fluid via</th></tr>
      <tr><td>T*</td><td>k<sub>B</sub>T / ε</td><td>ε in J, T in K (k<sub>B</sub> = 1.380649×10⁻²³ J/K)</td></tr>
      <tr><td>r*</td><td>r / σ</td><td>σ in m</td></tr>
      <tr><td>B₂*</td><td>B₂ / σ³</td><td>B₂ in m³</td></tr>
      <tr><td>(μ*)²</td><td>μ² / (4πε₀&thinsp;ε&thinsp;σ³)</td><td>μ in C·m (1 D = 3.33564×10⁻³⁰ C·m)</td></tr>
      <tr><td>n_eff</td><td>−3(B₂*+T*B₂*′) / (2T*B₂*′+T*²B₂*″)</td><td>dimensionless</td></tr>
    </table>
  </details>

  <div id="status">loading wasm…</div>

  <div id="plots"></div>

  <div class="row" style="margin-top:14px; display:flex; align-items:center; gap:12px;">
    <button id="copy" type="button">Copy table</button>
    <span class="note">copies the table as TSV (paste into Excel / Sheets)</span>
  </div>
  <div id="tablewrap"></div>

<script>
const WASM_B64 = "__WASM_B64__";

// ---- shared compute core (identical logic to node/run-aot-browser.mjs) ----
const ENV = { env: { exp: Math.exp, ln: Math.log, log10: Math.log10,
                     sin: Math.sin, cos: Math.cos, tan: Math.tan, powf: Math.pow } };
let ex = null; // our module's exports

function compileChild(dsl) {
  const enc = new TextEncoder().encode(dsl);
  const sp = ex.poc_alloc(enc.length);
  new Uint8Array(ex.memory.buffer, sp, enc.length).set(enc);
  const ret = ex.poc_compile_wasm(sp, enc.length); // BigInt
  ex.poc_dealloc(sp, enc.length);
  if (ret === 0n) throw new Error("could not parse potential");
  const ptr = Number(ret >> 32n), len = Number(ret & 0xffffffffn);
  const bytes = new Uint8Array(ex.memory.buffer, ptr, len).slice();
  ex.poc_free(ptr, len);
  return bytes;
}
function makePotential(dsl) {
  const bytes = compileChild(dsl);                 // child module is tiny (<4KB)
  const inst = new WebAssembly.Instance(new WebAssembly.Module(bytes), ENV);
  return { fn: inst.exports.potential, size: bytes.length };
}
function b2derivs(fn, eps, sig, T, n = 40000) {
  // one-pass composite Simpson over s in [0,1), r = s/(1-s), of the three
  // integrands for [B2, dB2/dT, d2B2/dT2] on the SAME grid. V(r) is
  // T-independent, so the Boltzmann-factor derivatives are exact:
  //   B2'  integrand = e^{-V/T} (V/T^2) r^2
  //   B2'' integrand = e^{-V/T} (V^2/T^4 - 2V/T^3) r^2
  let s0 = 0, s1 = 0, s2 = 0;
  for (let i = 0; i <= n; i++) {
    const s = i / n, om = 1 - s;
    let f0 = 0, f1 = 0, f2 = 0;
    if (om > 0) {
      const r = s / om, w = (r * r) / (om * om); // r^2 * Jacobian
      const V = fn(r, eps, sig);
      if (Number.isFinite(V)) {
        const e = Math.exp(-V / T), t2 = T * T;
        f0 = (e - 1) * w;
        f1 = (e * V / t2) * w;
        f2 = (e * (V * V / (t2 * t2) - 2 * V / (t2 * T))) * w;
      } else {
        f0 = -w; // repulsive core: e^{-V/T} -> 0, derivatives -> 0
      }
      if (!Number.isFinite(f0)) f0 = 0;
      if (!Number.isFinite(f1)) f1 = 0;
      if (!Number.isFinite(f2)) f2 = 0;
    }
    const wt = i === 0 || i === n ? 1 : i % 2 === 1 ? 4 : 2;
    s0 += wt * f0; s1 += wt * f1; s2 += wt * f2;
  }
  const k = (-2 * Math.PI) / (3 * n);
  const b2 = k * s0, db2 = k * s1, d2b2 = k * s2;
  return { b2, db2, d2b2, neff: neffFrom(b2, db2, d2b2, T) };
}
// n_eff from B2 and its first two T-derivatives (potter's formula).
const neffFrom = (b2, db2, d2b2, T) =>
  (-3 * (b2 + T * db2)) / (2 * T * db2 + T * T * d2b2);

// Closed-form REDUCED B2*(u) for a Mie(n–m) potential and its first two
// u-derivatives (u = T/eps). The series is originally Lennard-Jones's (later
// restated conveniently by Sadus, J. Chem. Phys. 149, 074504 (2018)):
//   B2* = (2π/3) y^{3/(n-m)} [ Γ((n-3)/n) − (3/n) Σ_{i≥1} Γ((im-3)/n) y^i/i! ]
//   y   = (n/(n-m)) ((n-m)/m)^{m/n} u^{-(n-m)/n}
// LJ is the special case (n,m) = (12,6). Differentiated analytically via y(u).
function mieReduced(u, n, m) {
  const beta = (n - m) / n, A = (n / (n - m)) * ((n - m) / m) ** (m / n);
  const y = A * u ** (-beta), p = 3 / (n - m), Ga = ex.poc_tgamma((n - 3) / n);
  let S = 0, Sp = 0, Spp = 0, fact = 1;
  for (let i = 1; i < 200; i++) {
    fact *= i; // i!
    const termS = ex.poc_tgamma((i * m - 3) / n) * y ** i / fact;
    if (!Number.isFinite(termS)) break;
    S += termS; Sp += (termS * i) / y; Spp += (termS * i * (i - 1)) / (y * y);
  }
  const H = Ga - (3 / n) * S, Hp = -(3 / n) * Sp, Hpp = -(3 / n) * Spp;
  const G = y ** p * H;
  const Gp = p * y ** (p - 1) * H + y ** p * Hp;
  const Gpp = p * (p - 1) * y ** (p - 2) * H + 2 * p * y ** (p - 1) * Hp + y ** p * Hpp;
  const yp = (-beta * y) / u, ypp = (beta * (beta + 1) * y) / (u * u), c = (2 * Math.PI) / 3;
  return { g0: c * G, g1: c * Gp * yp, g2: c * (Gpp * yp * yp + Gp * ypp) };
}

// Scale the reduced Mie series to real (eps, sig) and form { b2, db2, d2b2, neff }.
// Chain rule in u = T/eps: d/dT = (1/eps) d/du, d²/dT² = (1/eps²) d²/du².
function mieExact(u, eps, sig3, T, n, m) {
  const s = mieReduced(u, n, m);
  const b2 = sig3 * s.g0, db2 = (sig3 * s.g1) / eps, d2b2 = (sig3 * s.g2) / (eps * eps);
  return { b2, db2, d2b2, neff: neffFrom(b2, db2, d2b2, T) };
}

// ---- UI ----
const $ = (id) => document.getElementById(id);
const presetSel = $("preset"), dslEl = $("dsl");
const nwrap = $("nwrap"), nexp = $("nexp"), mwrap = $("mwrap"), mexp = $("mexp");
const mu2wrap = $("mu2wrap"), mu2el = $("mu2");
const lamwrap = $("lamwrap"), lamel = $("lam");

// Mie (n–m) normalization constant: u = C ε [(σ/r)^n − (σ/r)^m], LJ(12-6) -> C=4.
const mieC = (n, m) => (n / (n - m)) * (n / m) ** (m / (n - m));

const STOCKMAYER_FORMULA = "4*eps*((sig/r)**12 - (sig/r)**6) - eps*mu2*(sig/r)**3*[2cosθ₁cosθ₂ - sinθ₁sinθ₂cosφ]";
const SW_FORMULA = "∞ (r<σ),  −ε (σ<r<λσ),  0 (r>λσ)";
function syncPreset() {
  const p = presetSel.value;
  nwrap.hidden = !(p === "inv" || p === "mie");
  mwrap.hidden = p !== "mie";
  mu2wrap.hidden = p !== "stockmayer";
  lamwrap.hidden = p !== "sw";
  if (p === "lj") {
    dslEl.value = "4*eps*((sig/r)**12 - (sig/r)**6)"; dslEl.readOnly = true;
  } else if (p === "inv") {
    dslEl.value = `eps*(sig/r)**${parseInt(nexp.value) || 12}`; dslEl.readOnly = true;
  } else if (p === "mie") {
    const n = parseInt(nexp.value) || 12, m = parseInt(mexp.value) || 6;
    dslEl.value = `${mieC(n, m)}*eps*((sig/r)**${n} - (sig/r)**${m})`; dslEl.readOnly = true;
  } else if (p === "stockmayer") {
    dslEl.value = STOCKMAYER_FORMULA;
    dslEl.readOnly = true; // informational only — computed by 4-D cubature, not the DSL
  } else if (p === "exp") {
    dslEl.value = "eps*exp(-r/sig)"; dslEl.readOnly = true; // reduced exp(-r), purely repulsive
  } else if (p === "sw") {
    dslEl.value = SW_FORMULA; dslEl.readOnly = true; // informational — closed-form, not the DSL
  } else {
    // leaving Stockmayer/SW for Custom: their formula is not valid DSL, so seed a default
    if (dslEl.value === STOCKMAYER_FORMULA || dslEl.value === SW_FORMULA)
      dslEl.value = "4*eps*((sig/r)**12 - (sig/r)**6)";
    dslEl.readOnly = false;
  }
}

// Recompute on any control change so the inputs feel live (the n/m exponents,
// preset, eps/sig, and the temperature range all take effect immediately).
const recompute = () => { if (ex) compute(); };
presetSel.onchange = () => { syncPreset(); recompute(); };
nexp.oninput = () => { if (presetSel.value === "inv" || presetSel.value === "mie") syncPreset(); };
mexp.oninput = () => { if (presetSel.value === "mie") syncPreset(); };
nexp.onchange = () => { if (presetSel.value === "inv" || presetSel.value === "mie") { syncPreset(); recompute(); } };
mexp.onchange = () => { if (presetSel.value === "mie") { syncPreset(); recompute(); } };
mu2el.onchange = () => { if (presetSel.value === "stockmayer") { syncPreset(); recompute(); } };
lamel.onchange = () => { if (presetSel.value === "sw") recompute(); }; // SW formula is static in λ

// Exact closed-form { b2, db2, d2b2, neff } for a preset, or null for custom.
function exactFor(T, eps, sig) {
  const p = presetSel.value, u = T / eps, sig3 = sig ** 3;
  if (p === "lj") return mieExact(u, eps, sig3, T, 12, 6);
  if (p === "mie") {
    const n = parseInt(nexp.value) || 12, m = parseInt(mexp.value) || 6;
    if (!(n > m && m > 3)) return null; // need n > m and m > 3 (B2 tail converges)
    return mieExact(u, eps, sig3, T, n, m);
  }
  if (p === "inv") {
    const n = parseInt(nexp.value) || 12;
    if (n <= 3) return null; // B2 diverges for n <= 3
    const q = 3 / n, a = ((2 * Math.PI) / 3) * sig3 * ex.poc_tgamma(1 - q);
    const b2 = a * u ** (-q);
    const db2 = (a * (-q) * u ** (-q - 1)) / eps;
    const d2b2 = (a * q * (q + 1) * u ** (-q - 2)) / (eps * eps);
    return { b2, db2, d2b2, neff: n }; // n_eff == n exactly
  }
  return null; // custom: no closed form
}

// High-T limit of n_eff is the repulsive exponent n (n_eff -> n as T -> inf).
// At low T, n_eff -> 0 for any potential with an attractive well (NOT m -- m is
// just the Mie attractive exponent, not a limit of n_eff).
function repExponent() {
  const p = presetSel.value;
  if (p === "lj" || p === "stockmayer") return 12; // LJ repulsive core -> high-T limit 12
  if (p === "mie" || p === "inv") return parseInt(nexp.value) || 12;
  return NaN;
}

let lastRows = [], lastHasExact = false; // retained for "Copy table"

// T grid: linear or geometric (log) spacing between tmin and tmax.
function tGrid(tmin, tmax, np, log) {
  const out = [];
  for (let i = 0; i < np; i++) {
    const f = np === 1 ? 0 : i / (np - 1);
    out.push(log ? tmin * (tmax / tmin) ** f : tmin + (tmax - tmin) * f);
  }
  return out;
}

// Reduced Stockmayer via the wasm export (used by the Stockmayer preset).
function stockmayerReduced(tstar, mu2, reltol = 1e-3) {
  const out = ex.poc_alloc(32); // 4 * f64
  ex.poc_stockmayer(tstar, mu2, reltol, out);
  const dv = new DataView(ex.memory.buffer);
  const r = {
    b2: dv.getFloat64(out, true),
    db2: dv.getFloat64(out + 8, true),
    d2b2: dv.getFloat64(out + 16, true),
    neff: dv.getFloat64(out + 24, true),
  };
  ex.poc_dealloc(out, 32);
  return r;
}

// Build one result row for temperature T with the current preset/params.
function computeRow(preset, pot, T, eps, sig) {
  if (preset === "stockmayer") {
    const mu2 = parseFloat($("mu2").value) || 0;
    const r = stockmayerReduced(T / eps, mu2);   // reduced (ε=σ=1)
    const s3 = sig ** 3;
    return { T, num: s3 * r.b2, db2: (s3 * r.db2) / eps,
             d2b2: (s3 * r.d2b2) / (eps * eps), neff: r.neff, ex: null };
  }
  if (preset === "sw") {
    // Square-well V = ∞ (r<σ), −ε (σ<r<λσ), 0 (r>λσ): closed-form reduced B₂*(T*,λ).
    const lam = parseFloat($("lam").value) || 1.5;
    const a = lam ** 3 - 1, u = 1 / T, eu = Math.exp(u), c = (2 * Math.PI) / 3;
    const b2 = c * (1 - a * (eu - 1));
    const db2 = c * a * u * u * eu;
    const d2b2 = -c * a * u ** 3 * eu * (2 + u);
    return { T, num: b2, db2, d2b2, neff: neffFrom(b2, db2, d2b2, T), ex: null };
  }
  const d = b2derivs(pot.fn, eps, sig, T);
  return { T, num: d.b2, db2: d.db2, d2b2: d.d2b2, neff: d.neff, ex: exactFor(T, eps, sig) };
}

let runGen = 0; // generation token: a newer run cancels an older in-flight one

async function compute() {
  const gen = ++runGen;
  const preset = presetSel.value;
  const eps = 1, sig = 1; // reduced model potentials: ε = σ = 1 (axes are B₂/σ³ vs k_BT/ε)
  let tmin = parseFloat($("tmin").value), tmax = parseFloat($("tmax").value);
  const np = Math.max(2, parseInt($("npts").value) || 2);
  const log = $("tspace").value === "log";
  if (log && tmin <= 0) tmin = 1e-3;

  let pot = null;
  if (preset !== "stockmayer" && preset !== "sw") {
    try { pot = makePotential(dslEl.value); }
    catch (e) { $("status").innerHTML = `<span class="err">✗ ${e.message}</span>`; return; }
  }

  const Ts = tGrid(tmin, tmax, np, log);
  const rows = [];
  let i = 0;
  while (i < Ts.length) {
    if (gen !== runGen) return; // a newer run started — abandon this one
    const sliceStart = performance.now();
    try {
      do {
        rows.push(computeRow(preset, pot, Ts[i], eps, sig));
        i++;
      } while (i < Ts.length && performance.now() - sliceStart < 16);
    } catch (e) {
      $("status").innerHTML = `<span class="err">✗ ${e.message}</span>`;
      return;
    }

    const hasExact = rows.some(r => r.ex);
    lastRows = rows.slice();
    lastHasExact = hasExact;
    renderTable(rows, hasExact);
    renderPlotly(rows, hasExact, log);
    $("status").innerHTML = i < Ts.length
      ? `computing ${i}/${Ts.length}…`
      : `✓ ${preset === "stockmayer" ? "Stockmayer 4-D cubature" : "compiled <code>" +
          dslEl.value.replace(/</g, "&lt;") + "</code>"} — ${np} temperatures ` +
        `(${log ? "log" : "linear"} spacing): B₂, its first two T-derivatives, and n_eff.` +
        (hasExact ? "" : " <span class=note>(no closed-form overlay)</span>");
    if (i < Ts.length) await new Promise(r => setTimeout(r, 0));
  }
}

function renderTable(rows, hasExact) {
  let h = "<table><tr><th>k_BT/ε</th><th>B₂/σ³</th><th>dB₂*/dT*</th><th>d²B₂*/dT*²</th>" +
          "<th>n_eff</th>" + (hasExact ? "<th>n_eff*</th>" : "") + "</tr>";
  for (const r of rows) {
    const ne = r.ex ? r.ex.neff : NaN;
    h += `<tr><td>${r.T.toFixed(3)}</td><td>${r.num.toFixed(4)}</td>` +
         `<td>${r.db2.toFixed(4)}</td><td>${r.d2b2.toFixed(4)}</td>` +
         `<td>${Number.isFinite(r.neff) ? r.neff.toFixed(3) : "—"}</td>`;
    if (hasExact)
      h += `<td>${Number.isFinite(ne) ? ne.toFixed(3) : "—"}</td>`;
    h += "</tr>";
  }
  $("tablewrap").innerHTML = h + "</table>" +
    (hasExact
      ? "<div class=note>n_eff* = exact. High-T limit is the repulsive exponent n; " +
        "for LJ/Mie n_eff → 0 as T → 0 (not m). Inverse-power is flat at n.</div>"
      : "");
}

// Four vertically-stacked subplots (B₂, dB₂/dT, d²B₂/dT², n_eff) sharing the T
// axis. opts (defaults = reduced model-potential mode):
//   xlabel, panels:[B₂,dB₂,d²B₂] titles (n_eff is fixed), hover (x label),
//   series2: null | {key, name, color, dash} for a second line per panel,
//   ref: bool (draw the n=repExponent() dashed high-T reference on n_eff).
function renderPlotly(rows, hasExact, logX, opts = {}) {
  const host = $("plots");
  if (!host) return;
  if (typeof Plotly === "undefined") {
    host.innerHTML = "<div class=note>Plots are rendered with Plotly (loaded from a CDN). " +
      "Offline file:// has no network, so the plots are unavailable here — the table and " +
      "“Copy table” still work.</div>";
    return;
  }
  const o = {
    xlabel: "k_BT/ε",
    panels: ["B₂/σ³", "dB₂*/dT*", "d²B₂*/dT*²"],
    hover: "k_BT/ε",
    series2: null,
    ref: true,
    ...opts,
  };
  const Ts = rows.map(r => r.T);
  const BLUE = "#2a6df4", RED = "#e0533d";
  const line = (y, axis, color, dash) => ({
    x: Ts, y, type: "scatter", mode: "lines",
    line: { color: color || BLUE, width: 2, dash: dash || "solid" },
    yaxis: axis, hovertemplate: `${o.hover}=%{x:.3g}<br>%{y:.5g}<extra></extra>`,
  });
  const dots = (y, axis) => ({
    x: Ts, y, type: "scatter", mode: "markers", marker: { color: RED, size: 6 },
    yaxis: axis, hovertemplate: "exact %{y:.5g}<extra></extra>",
  });

  const traces = [
    line(rows.map(r => r.num), "y4"),
    line(rows.map(r => r.db2), "y3"),
    line(rows.map(r => r.d2b2), "y2"),
    line(rows.map(r => r.neff), "y"),
  ];
  if (hasExact) {
    traces.push(dots(rows.map(r => (r.ex ? r.ex.b2 : null)), "y4"));
    traces.push(dots(rows.map(r => (r.ex ? r.ex.db2 : null)), "y3"));
    traces.push(dots(rows.map(r => (r.ex ? r.ex.d2b2 : null)), "y2"));
    traces.push(dots(rows.map(r => (r.ex ? r.ex.neff : null)), "y"));
  }
  if (o.series2) {
    const k = o.series2.key, c = o.series2.color, d = o.series2.dash || "dot";
    traces[0].name = "classical"; // blue series gets a legend name
    const s = (sel, axis) => { const t = line(rows.map(r => (r[k] ? r[k][sel] : null)), axis, c, d);
      t.name = o.series2.name; return t; };
    traces.push(s("b2", "y4"), s("db2", "y3"), s("d2b2", "y2"), s("neff", "y"));
  }

  const band = (lo, hi, title) => ({
    domain: [lo, hi], title: { text: title, font: { size: 12 } }, zeroline: true,
    automargin: true, ticks: "outside", tickfont: { size: 10 },
    showline: true, linecolor: "#ddd",
  });
  const layout = {
    height: 660, margin: { l: 72, r: 16, t: 20, b: 44 }, showlegend: !!o.series2,
    legend: { orientation: "h", y: 1.02, x: 0 },
    font: { size: 11 }, paper_bgcolor: "#fff", plot_bgcolor: "#fff",
    xaxis: {
      domain: [0, 1], anchor: "y", title: { text: o.xlabel },
      type: logX ? "log" : "linear", ticks: "outside", showline: true, linecolor: "#ddd",
    },
    yaxis: band(0.0, 0.21, "n_eff"),
    yaxis2: band(0.27, 0.47, o.panels[2]),
    yaxis3: band(0.53, 0.73, o.panels[1]),
    yaxis4: band(0.79, 1.0, o.panels[0]),
  };
  if (o.ref) {
    // dashed reference at the repulsive exponent n on the n_eff (bottom) panel.
    const ref = repExponent();
    if (Number.isFinite(ref)) {
      layout.shapes = [{ type: "line", xref: "paper", x0: 0, x1: 1, yref: "y", y0: ref, y1: ref,
        line: { color: "#bbb", width: 1, dash: "dash" } }];
      layout.annotations = [{ xref: "paper", x: 0.012, yref: "y", y: ref,
        text: "n = " + ref + " (high-T limit)", showarrow: false,
        font: { size: 10, color: "#999" }, xanchor: "left", yanchor: "bottom" }];
    }
  }
  Plotly.react(host, traces, layout, { displayModeBar: false, responsive: true });
}

// ---- copy table to clipboard (TSV; Excel/Sheets-friendly) ----
function fallbackCopy(text, done) {
  const ta = document.createElement("textarea");
  ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
  document.body.appendChild(ta); ta.focus(); ta.select();
  try { document.execCommand("copy"); done(); } catch (e) { /* ignore */ }
  document.body.removeChild(ta);
}
function copyTable() {
  if (!lastRows.length) return;
  const cols = ["kBT/eps", "B2/sig^3", "dB2*/dT*", "d2B2*/dT*^2", "n_eff"];
  if (lastHasExact) cols.push("n_eff_exact");
  const lines = [cols.join("\t")];
  for (const r of lastRows) {
    const row = [r.T, r.num, r.db2, r.d2b2, r.neff];
    if (lastHasExact) row.push(r.ex ? r.ex.neff : "");
    lines.push(row.join("\t"));
  }
  const text = lines.join("\n");
  const btn = $("copy"), label = btn.textContent;
  const done = () => { btn.textContent = "copied ✓"; setTimeout(() => (btn.textContent = label), 1200); };
  if (navigator.clipboard && navigator.clipboard.writeText)
    navigator.clipboard.writeText(text).then(done, () => fallbackCopy(text, done));
  else fallbackCopy(text, done);
}

// ---- boot ----
(async () => {
  try {
    const bytes = Uint8Array.from(atob(WASM_B64), c => c.charCodeAt(0));
    const { instance } = await WebAssembly.instantiate(bytes, {});
    ex = instance.exports;
    $("go").disabled = false;
    $("go").onclick = compute;
    $("copy").onclick = copyTable;
    $("tspace").onchange = compute;
    for (const id of ["tmin", "tmax", "npts"]) $(id).onchange = compute;
    $("status").textContent = "ready.";
    syncPreset();
    compute();
  } catch (e) {
    $("status").innerHTML = `<span class="err">failed to load wasm: ${e.message}</span>`;
  }
})();
</script>
</body>
</html>
