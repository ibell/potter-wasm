<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>potter-poc — B₂ in the browser</title>
<style>
  :root { --fg:#1a1a2e; --mut:#666; --accent:#2a6df4; --exact:#e0533d; --line:#ddd; }
  * { box-sizing: border-box; }
  body { font: 15px/1.5 -apple-system, system-ui, sans-serif; color: var(--fg);
         max-width: 880px; margin: 24px auto; padding: 0 16px; }
  h1 { font-size: 20px; margin: 0 0 2px; }
  .sub { color: var(--mut); margin: 0 0 18px; font-size: 13px; }
  fieldset { border: 1px solid var(--line); border-radius: 8px; padding: 12px 14px; margin: 0 0 14px; }
  legend { font-weight: 600; font-size: 13px; padding: 0 6px; }
  label { display: inline-block; margin-right: 14px; font-size: 13px; }
  input, select, textarea { font: inherit; padding: 4px 6px; border: 1px solid #bbb; border-radius: 5px; }
  input[type=number] { width: 72px; }
  textarea { width: 100%; font-family: ui-monospace, Menlo, monospace; font-size: 13px; margin-top: 6px; }
  button { font: inherit; font-weight: 600; padding: 7px 18px; border: 0; border-radius: 6px;
           background: var(--accent); color: #fff; cursor: pointer; }
  button:disabled { background: #aaa; cursor: default; }
  .row { margin: 8px 0; }
  .note { font-size: 12px; color: var(--mut); }
  #status { font-size: 13px; margin: 10px 0; }
  .err { color: var(--exact); }
  table { border-collapse: collapse; width: 100%; margin-top: 10px; font-variant-numeric: tabular-nums; }
  th, td { text-align: right; padding: 3px 10px; border-bottom: 1px solid #eee; font-size: 13px; }
  th { color: var(--mut); font-weight: 600; }
  td:first-child, th:first-child { text-align: left; }
  canvas { border: 1px solid var(--line); border-radius: 8px; margin-top: 12px; max-width: 100%; }
  code { background: #f3f3f7; padding: 1px 5px; border-radius: 4px; font-size: 12.5px; }
  .layout { display: flex; gap: 18px; flex-wrap: wrap; align-items: flex-start; }
  .layout > div { flex: 1 1 360px; }
  #plots { width: 100%; min-height: 200px; }
</style>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
</head>
<body>
  <h1>Second virial coefficient B₂(T) — in the browser</h1>
  <p class="sub">Type a pair potential V(r). It is compiled to a WebAssembly module
     <em>in your browser</em> (AOT) and run natively to integrate
     B₂ = −2π ∫₀<sup>∞</sup> (e<sup>−V/T</sup>−1) r² dr. Because V(r) is
     T-independent, the same pass also returns the first two T-derivatives
     (analytically) and the effective repulsive exponent
     n_eff = −3(B₂+T·B₂′)/(2T·B₂′+T²·B₂″). Reduced units.</p>

  <fieldset>
    <legend>potential</legend>
    <div class="row">
      <label>preset
        <select id="preset">
          <option value="lj">Lennard-Jones (12-6)</option>
          <option value="inv">Inverse power  ε(σ/r)ⁿ</option>
          <option value="custom">Custom…</option>
        </select>
      </label>
      <label id="nwrap" hidden>n <input id="nexp" type="number" value="12" min="4" step="1" /></label>
      <label>ε <input id="eps" type="number" value="1" step="0.1" /></label>
      <label>σ <input id="sig" type="number" value="1" step="0.1" /></label>
    </div>
    <div class="row">
      <textarea id="dsl" rows="2" spellcheck="false">4*eps*((sig/r)**12 - (sig/r)**6)</textarea>
      <div class="note">Python-like: <code>+ - * /</code>, <code>**</code> power,
        <code>exp ln log sqrt sin cos abs pow</code>, variables <code>r</code>, <code>eps</code>, <code>sig</code>.</div>
    </div>
  </fieldset>

  <fieldset>
    <legend>temperature range</legend>
    <label>T*min <input id="tmin" type="number" value="1.3" step="0.1" /></label>
    <label>T*max <input id="tmax" type="number" value="8" step="0.5" /></label>
    <label>points <input id="npts" type="number" value="24" min="2" step="1" /></label>
    <label>spacing
      <select id="tspace">
        <option value="lin">linear</option>
        <option value="log">log</option>
      </select>
    </label>
    <button id="go" disabled>Compute B₂(T)</button>
  </fieldset>

  <div id="status">loading wasm…</div>

  <div id="plots"></div>

  <div class="row" style="margin-top:14px; display:flex; align-items:center; gap:12px;">
    <button id="copy" type="button">Copy table</button>
    <span class="note">copies the table as TSV (paste into Excel / Sheets)</span>
  </div>
  <div id="tablewrap"></div>

<script>
const WASM_B64 = "__WASM_B64__";

// ---- shared compute core (identical logic to node/run-aot-browser.mjs) ----
const ENV = { env: { exp: Math.exp, ln: Math.log, log10: Math.log10,
                     sin: Math.sin, cos: Math.cos, tan: Math.tan, powf: Math.pow } };
let ex = null; // our module's exports

function compileChild(dsl) {
  const enc = new TextEncoder().encode(dsl);
  const sp = ex.poc_alloc(enc.length);
  new Uint8Array(ex.memory.buffer, sp, enc.length).set(enc);
  const ret = ex.poc_compile_wasm(sp, enc.length); // BigInt
  ex.poc_dealloc(sp, enc.length);
  if (ret === 0n) throw new Error("could not parse potential");
  const ptr = Number(ret >> 32n), len = Number(ret & 0xffffffffn);
  const bytes = new Uint8Array(ex.memory.buffer, ptr, len).slice();
  ex.poc_free(ptr, len);
  return bytes;
}
function makePotential(dsl) {
  const bytes = compileChild(dsl);                 // child module is tiny (<4KB)
  const inst = new WebAssembly.Instance(new WebAssembly.Module(bytes), ENV);
  return { fn: inst.exports.potential, size: bytes.length };
}
function b2derivs(fn, eps, sig, T, n = 40000) {
  // one-pass composite Simpson over s in [0,1), r = s/(1-s), of the three
  // integrands for [B2, dB2/dT, d2B2/dT2] on the SAME grid. V(r) is
  // T-independent, so the Boltzmann-factor derivatives are exact:
  //   B2'  integrand = e^{-V/T} (V/T^2) r^2
  //   B2'' integrand = e^{-V/T} (V^2/T^4 - 2V/T^3) r^2
  let s0 = 0, s1 = 0, s2 = 0;
  for (let i = 0; i <= n; i++) {
    const s = i / n, om = 1 - s;
    let f0 = 0, f1 = 0, f2 = 0;
    if (om > 0) {
      const r = s / om, w = (r * r) / (om * om); // r^2 * Jacobian
      const V = fn(r, eps, sig);
      if (Number.isFinite(V)) {
        const e = Math.exp(-V / T), t2 = T * T;
        f0 = (e - 1) * w;
        f1 = (e * V / t2) * w;
        f2 = (e * (V * V / (t2 * t2) - 2 * V / (t2 * T))) * w;
      } else {
        f0 = -w; // repulsive core: e^{-V/T} -> 0, derivatives -> 0
      }
      if (!Number.isFinite(f0)) f0 = 0;
      if (!Number.isFinite(f1)) f1 = 0;
      if (!Number.isFinite(f2)) f2 = 0;
    }
    const wt = i === 0 || i === n ? 1 : i % 2 === 1 ? 4 : 2;
    s0 += wt * f0; s1 += wt * f1; s2 += wt * f2;
  }
  const k = (-2 * Math.PI) / (3 * n);
  const b2 = k * s0, db2 = k * s1, d2b2 = k * s2;
  return { b2, db2, d2b2, neff: neffFrom(b2, db2, d2b2, T) };
}
// n_eff from B2 and its first two T-derivatives (potter's formula).
const neffFrom = (b2, db2, d2b2, T) =>
  (-3 * (b2 + T * db2)) / (2 * T * db2 + T * T * d2b2);

// Exact LJ (12-6) REDUCED B2 and its first two u-derivatives (u = T/eps), from the
// HCB Gamma-series differentiated term-by-term. Mirrors Rust b2_lj_series_derivs.
function ljReducedSeries(u, nterms = 80) {
  let factorial = 1, g0 = 0, g1 = 0, g2 = 0;
  for (let j = 0; j < nterms; j++) {
    if (j > 0) factorial *= j;
    const p = (2 * j + 1) / 2;
    const coeff = -((2 ** p) / (4 * factorial)) * ex.poc_tgamma((2 * j - 1) / 4);
    const q = (2 * j + 1) / 4;
    const a0 = coeff * u ** (-q);
    const a1 = coeff * (-q) * u ** (-q - 1);
    const a2 = coeff * q * (q + 1) * u ** (-q - 2);
    if (Number.isFinite(a0)) g0 += a0;
    if (Number.isFinite(a1)) g1 += a1;
    if (Number.isFinite(a2)) g2 += a2;
  }
  const c = (2 * Math.PI) / 3;
  return { g0: c * g0, g1: c * g1, g2: c * g2 };
}

// ---- UI ----
const $ = (id) => document.getElementById(id);
const presetSel = $("preset"), dslEl = $("dsl"), nwrap = $("nwrap"), nexp = $("nexp");

function syncPreset() {
  const p = presetSel.value;
  nwrap.hidden = p !== "inv";
  if (p === "lj") { dslEl.value = "4*eps*((sig/r)**12 - (sig/r)**6)"; dslEl.readOnly = true; }
  else if (p === "inv") { dslEl.value = `eps*(sig/r)**${parseInt(nexp.value) || 12}`; dslEl.readOnly = true; }
  else { dslEl.readOnly = false; }
}
presetSel.onchange = syncPreset;
nexp.oninput = () => { if (presetSel.value === "inv") syncPreset(); };

// Exact closed-form { b2, db2, d2b2, neff } for a preset, or null for custom.
// Chain rule in u = T/eps: dB2/dT = (dB2/du)/eps, d2B2/dT2 = (d2B2/du2)/eps^2.
function exactFor(T, eps, sig) {
  const p = presetSel.value, u = T / eps, sig3 = sig ** 3;
  if (p === "lj") {
    const s = ljReducedSeries(u);
    const b2 = sig3 * s.g0, db2 = (sig3 * s.g1) / eps, d2b2 = (sig3 * s.g2) / (eps * eps);
    return { b2, db2, d2b2, neff: neffFrom(b2, db2, d2b2, T) };
  }
  if (p === "inv") {
    const n = parseInt(nexp.value) || 12;
    if (n <= 3) return null; // B2 diverges for n <= 3
    const q = 3 / n, a = ((2 * Math.PI) / 3) * sig3 * ex.poc_tgamma(1 - q);
    const b2 = a * u ** (-q);
    const db2 = (a * (-q) * u ** (-q - 1)) / eps;
    const d2b2 = (a * q * (q + 1) * u ** (-q - 2)) / (eps * eps);
    return { b2, db2, d2b2, neff: n }; // n_eff == n exactly
  }
  return null; // custom: no closed form
}

// the repulsive exponent the high-T limit should approach, for a reference line.
function repExponent() {
  const p = presetSel.value;
  if (p === "lj") return 12;
  if (p === "inv") return parseInt(nexp.value) || 12;
  return NaN;
}

let lastRows = [], lastHasExact = false; // retained for "Copy table"

// T grid: linear or geometric (log) spacing between tmin and tmax.
function tGrid(tmin, tmax, np, log) {
  const out = [];
  for (let i = 0; i < np; i++) {
    const f = np === 1 ? 0 : i / (np - 1);
    out.push(log ? tmin * (tmax / tmin) ** f : tmin + (tmax - tmin) * f);
  }
  return out;
}

function compute() {
  const eps = parseFloat($("eps").value), sig = parseFloat($("sig").value);
  let tmin = parseFloat($("tmin").value), tmax = parseFloat($("tmax").value);
  const np = Math.max(2, parseInt($("npts").value) || 2);
  const log = $("tspace").value === "log";
  if (log && tmin <= 0) tmin = 1e-3; // geometric spacing needs a positive lower bound
  let pot;
  try { pot = makePotential(dslEl.value); }
  catch (e) { $("status").innerHTML = `<span class="err">✗ ${e.message}</span>`; return; }

  const rows = [];
  let hasExact = false;
  for (const T of tGrid(tmin, tmax, np, log)) {
    const d = b2derivs(pot.fn, eps, sig, T);
    const exc = exactFor(T, eps, sig);
    if (exc) hasExact = true;
    rows.push({ T, num: d.b2, db2: d.db2, d2b2: d.d2b2, neff: d.neff, ex: exc });
  }
  lastRows = rows; lastHasExact = hasExact;
  $("status").innerHTML =
    `✓ compiled <code>${dslEl.value.replace(/</g,"&lt;")}</code> to a ${pot.size}-byte wasm module, ` +
    `run natively for ${np} temperatures (${log ? "log" : "linear"} spacing) ` +
    `— B₂, its first two T-derivatives, and n_eff.` +
    (hasExact ? "" : " <span class=note>(no closed form for a custom potential)</span>");
  renderTable(rows, hasExact);
  renderPlotly(rows, hasExact, log);
}

function renderTable(rows, hasExact) {
  let h = "<table><tr><th>T*</th><th>B₂</th><th>dB₂/dT</th><th>d²B₂/dT²</th>" +
          "<th>n_eff</th>" + (hasExact ? "<th>n_eff*</th>" : "") + "</tr>";
  for (const r of rows) {
    const ne = r.ex ? r.ex.neff : NaN;
    h += `<tr><td>${r.T.toFixed(3)}</td><td>${r.num.toFixed(4)}</td>` +
         `<td>${r.db2.toFixed(4)}</td><td>${r.d2b2.toFixed(4)}</td>` +
         `<td>${Number.isFinite(r.neff) ? r.neff.toFixed(3) : "—"}</td>`;
    if (hasExact)
      h += `<td>${Number.isFinite(ne) ? ne.toFixed(3) : "—"}</td>`;
    h += "</tr>";
  }
  $("tablewrap").innerHTML = h + "</table>" +
    (hasExact
      ? "<div class=note>n_eff* = exact (flat at n for inverse-power; → 12 for LJ at high T).</div>"
      : "");
}

// Four vertically-stacked subplots (B₂, dB₂/dT, d²B₂/dT², n_eff) sharing the T
// axis, drawn with Plotly. Numeric = blue line, exact (presets) = red markers.
function renderPlotly(rows, hasExact, logX) {
  const host = $("plots");
  if (!host) return;
  if (typeof Plotly === "undefined") {
    host.innerHTML = "<div class=note>Plots are rendered with Plotly (loaded from a CDN). " +
      "Offline file:// has no network, so the plots are unavailable here — the table and " +
      "“Copy table” still work.</div>";
    return;
  }
  const Ts = rows.map(r => r.T);
  const BLUE = "#2a6df4", RED = "#e0533d";
  const line = (y, axis) => ({
    x: Ts, y, type: "scatter", mode: "lines", line: { color: BLUE, width: 2 },
    yaxis: axis, hovertemplate: "T*=%{x:.3g}<br>%{y:.5g}<extra></extra>",
  });
  const dots = (y, axis) => ({
    x: Ts, y, type: "scatter", mode: "markers", marker: { color: RED, size: 6 },
    yaxis: axis, hovertemplate: "exact %{y:.5g}<extra></extra>",
  });

  const traces = [
    line(rows.map(r => r.num), "y4"),
    line(rows.map(r => r.db2), "y3"),
    line(rows.map(r => r.d2b2), "y2"),
    line(rows.map(r => r.neff), "y"),
  ];
  if (hasExact) {
    traces.push(dots(rows.map(r => (r.ex ? r.ex.b2 : null)), "y4"));
    traces.push(dots(rows.map(r => (r.ex ? r.ex.db2 : null)), "y3"));
    traces.push(dots(rows.map(r => (r.ex ? r.ex.d2b2 : null)), "y2"));
    traces.push(dots(rows.map(r => (r.ex ? r.ex.neff : null)), "y"));
  }

  const band = (lo, hi, title) => ({
    domain: [lo, hi], title: { text: title, font: { size: 12 } }, zeroline: true,
    automargin: true, ticks: "outside", tickfont: { size: 10 },
    showline: true, linecolor: "#ddd",
  });
  const layout = {
    height: 660, margin: { l: 72, r: 16, t: 20, b: 44 }, showlegend: false,
    font: { size: 11 }, paper_bgcolor: "#fff", plot_bgcolor: "#fff",
    xaxis: {
      domain: [0, 1], anchor: "y", title: { text: "T*" },
      type: logX ? "log" : "linear", ticks: "outside", showline: true, linecolor: "#ddd",
    },
    yaxis: band(0.0, 0.21, "n_eff"),
    yaxis2: band(0.27, 0.47, "d²B₂/dT²"),
    yaxis3: band(0.53, 0.73, "dB₂/dT"),
    yaxis4: band(0.79, 1.0, "B₂"),
  };
  // dashed reference at the repulsive exponent on the n_eff (bottom) panel
  const ref = repExponent();
  if (Number.isFinite(ref)) {
    layout.shapes = [{
      type: "line", xref: "paper", x0: 0, x1: 1, yref: "y", y0: ref, y1: ref,
      line: { color: "#bbb", width: 1, dash: "dash" },
    }];
    layout.annotations = [{
      xref: "paper", x: 0.012, yref: "y", y: ref, text: "n = " + ref + " (high-T limit)",
      showarrow: false, font: { size: 10, color: "#999" }, xanchor: "left", yanchor: "bottom",
    }];
  }
  Plotly.react(host, traces, layout, { displayModeBar: false, responsive: true });
}

// ---- copy table to clipboard (TSV; Excel/Sheets-friendly) ----
function fallbackCopy(text, done) {
  const ta = document.createElement("textarea");
  ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
  document.body.appendChild(ta); ta.focus(); ta.select();
  try { document.execCommand("copy"); done(); } catch (e) { /* ignore */ }
  document.body.removeChild(ta);
}
function copyTable() {
  if (!lastRows.length) return;
  const cols = ["T*", "B2", "dB2/dT", "d2B2/dT2", "n_eff"];
  if (lastHasExact) cols.push("n_eff_exact");
  const lines = [cols.join("\t")];
  for (const r of lastRows) {
    const row = [r.T, r.num, r.db2, r.d2b2, r.neff];
    if (lastHasExact) row.push(r.ex ? r.ex.neff : "");
    lines.push(row.join("\t"));
  }
  const text = lines.join("\n");
  const btn = $("copy"), label = btn.textContent;
  const done = () => { btn.textContent = "copied ✓"; setTimeout(() => (btn.textContent = label), 1200); };
  if (navigator.clipboard && navigator.clipboard.writeText)
    navigator.clipboard.writeText(text).then(done, () => fallbackCopy(text, done));
  else fallbackCopy(text, done);
}

// ---- boot ----
(async () => {
  try {
    const bytes = Uint8Array.from(atob(WASM_B64), c => c.charCodeAt(0));
    const { instance } = await WebAssembly.instantiate(bytes, {});
    ex = instance.exports;
    $("go").disabled = false;
    $("go").onclick = compute;
    $("copy").onclick = copyTable;
    $("tspace").onchange = compute;
    $("status").textContent = "ready.";
    syncPreset();
    compute();
  } catch (e) {
    $("status").innerHTML = `<span class="err">failed to load wasm: ${e.message}</span>`;
  }
})();
</script>
</body>
</html>
